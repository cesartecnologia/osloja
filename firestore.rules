rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid));
    }

    function sameCompany(empresaId) {
      return signedIn() && userDoc().data.empresaId == empresaId;
    }

    function isAdmin() {
      return signedIn() && userDoc().data.perfil == 'admin';
    }

    match /usuarios/{userId} {
      allow read: if signedIn() && (request.auth.uid == userId || sameCompany(resource.data.empresaId));
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if false;
    }

    match /empresa/{empresaId} {
      allow read: if sameCompany(empresaId) || (signedIn() && empresaId == 'default');
      allow update: if sameCompany(empresaId);
      allow create: if signedIn();
    }

    match /ordens_servico/{docId} {
      allow read: if sameCompany(resource.data.empresaId);
      allow create: if sameCompany(request.resource.data.empresaId);
      allow update: if sameCompany(resource.data.empresaId) && sameCompany(request.resource.data.empresaId);
      allow delete: if isAdmin() && sameCompany(resource.data.empresaId);
    }

    match /clientes/{docId} {
      allow read: if sameCompany(resource.data.empresaId);
      allow create: if sameCompany(request.resource.data.empresaId);
      allow update: if sameCompany(resource.data.empresaId) && sameCompany(request.resource.data.empresaId);
      allow delete: if isAdmin() && sameCompany(resource.data.empresaId);
    }

    match /produtos/{docId} {
      allow read: if sameCompany(resource.data.empresaId);
      allow create: if sameCompany(request.resource.data.empresaId);
      allow update: if sameCompany(resource.data.empresaId) && sameCompany(request.resource.data.empresaId);
      allow delete: if isAdmin() && sameCompany(resource.data.empresaId);
    }

    match /vendas/{docId} {
      allow read: if sameCompany(resource.data.empresaId);
      allow create: if sameCompany(request.resource.data.empresaId);
      allow update: if sameCompany(resource.data.empresaId) && sameCompany(request.resource.data.empresaId);
      allow delete: if isAdmin() && sameCompany(resource.data.empresaId);
    }

    match /counters/{empresaId} {
      allow read, write: if sameCompany(empresaId);
    }
  }
}
